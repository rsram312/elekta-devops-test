# ----------------------------------------------------------------------------
# Terraform
# ----------------------------------------------------------------------------

# Local plugin cache and module cache (large, regenerated by `terraform init`)
**/.terraform/

# Local state files (we use remote state, but Terraform may write a backup)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash logs
crash.log
crash.*.log

# Saved plan files (can contain secrets)
*.tfplan
tfplan
tfplan.txt

# Variable files - hold secrets, never commit. Example file IS committed.
*.tfvars
*.tfvars.json
!*.tfvars.example

# Override files (local dev only, by convention)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc

# ----------------------------------------------------------------------------
# OS / editor
# ----------------------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp